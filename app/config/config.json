{
  "version": "2.7.4",
  "default_style_config": "app/config/style_default.config.json",
  "ui": {
    "welcome_dialog": {
      "title": "Welcome to CARA",
      "message": "<b>Thanks for installing CARA</b>.<br><br>As this is your first time starting the application, I would recommend that you take a quick look at the <a href=\"manual://getting-started\">Getting Started</a> section of the manual.<br><br>It covers the most important aspects of configuring and using CARA, so that you will hopefully have a great time and enjoy using the application.<br><br>You will also find a link to CARA's YouTube channel with many tutorial videos<br>in the <b>Help menu</b>.<br><br>If you enjoy the project, please consider leaving a Star on the GitHub repository, subscribing to and liking the YouTube channel/videos, and spreading the word!<br><br>Best regards, Philipp."
    },
    "window": {
      "x": 100,
      "y": 100,
      "width": 1200,
      "height": 800
    },
    "panels": {
      "main": {
        "board": {
          "coordinates": {
            "show": true
          },
          "positional_plans": {
            "numbered_markers": {
              "enabled": true
            },
            "numbered_markers_2": {
              "enabled": true
            },
            "numbered_markers_3": {
              "enabled": true
            },
            "min_moves_for_plan": 2
          },
          "evaluation_bar": {
            "enabled": false,
            "max_depth_evaluation": 0,
            "update_interval_ms": 500,
            "default_threads_formula": {
              "formula": "1"
            },
            "scale_max": 10.0
          },
          "initial_fen": "rnbqkbnr/pppppppp/8/8/8/8/PPPPPPPP/RNBQKBNR w KQkq - 0 1"
        }
      },
      "detail": {
        "pgn_notation": {
          "placeholder_text": "PGN notation will appear here...",
          "formatting": {
            "annotations": {
              "use_symbols": true
            },
            "nags": {
              "show_text": true
            }
          }
        },
        "moveslist": {
          "copy_table": {
            "csv": {
              "delimiter": ",",
              "use_escaping": true,
              "always_quote_values": true
            },
            "tsv": {
              "delimiter": "\t",
              "use_escaping": false,
              "always_quote_values": false
            }
          }
        },
        "summary": {
          "placeholder_text_not_analyzed": "Run Game Analysis to view Game Summary",
          "placeholder_text_to_be_implemented": "to be implemented...",
          "evaluation_graph": {
            "scale_cap_cp": 1000.0
          },
          "phase_analysis": {
            "opening_moves": 15,
            "endgame_moves": 10
          },
          "highlights": {
            "max_per_phase": 7
          }
        },
        "player_stats": {
          "placeholder_text_no_player": "Select a player to view statistics",
          "placeholder_text_no_analyzed": "No analyzed games found for this player",
          "placeholder_text_no_source": "Select a data source above to view player statistics.",
          "placeholder_text_no_analyzed_players": "No players with at least 2 analyzed games found in selected database(s).",
          "placeholder_text_all_sections_hidden": "All player statistics sections are hidden. Use the Player Stats menu to show them again.",
          "section_visibility_hint": {
            "text": "Some sections have been toggled off, use the Player Stats menu if you want to toggle them back on."
          },
          "show_time_trends_unavailability_hint": true,
          "time_trends_unavailability_message": "Some sections are not available for the given data source, as they require (more) games with valid Date (tag) information.",
          "placeholder_text_loading": "Loading players...",
          "placeholder_text_calculating_stats": "Calculating statistics…",
          "placeholder_text_bulk_analysis_stats_disabled": "Disabled during bulk analysis.",
          "significant_moves": {
            "brilliant_moves": {
              "max_moves": 999
            },
            "misses": {
              "max_moves": 999
            },
            "blunders": {
              "max_moves": 999
            }
          },
          "analysis_coverage": {
            "show_banner": true,
            "thresholds": {
              "good_coverage_percent": 80,
              "moderate_coverage_percent": 50
            }
          },
          "accuracy_distribution": {
            "enabled": true,
            "skew_exponents": {
              "linear": 1,
              "high_accuracy_skew": 4,
              "very_high_accuracy_skew": 6.5
            },
            "bin_density_profiles": {
              "auto": {
                "min_bins": 5,
                "max_bins": 25,
                "range_divisor": 5
              },
              "fewer": {
                "min_bins": 5,
                "max_bins": 12,
                "range_divisor": 9
              },
              "more": {
                "min_bins": 14,
                "max_bins": 38,
                "range_divisor": 3.2
              }
            }
          },
          "top_games": {
            "max_best": 3,
            "max_worst": 3
          },
          "error_patterns": {
            "thresholds": {
              "phase_blunder_percentage": 20.0,
              "tactical_miss_count": 10,
              "opening_error_rate": 30.0,
              "high_cpl_threshold": 50.0,
              "missed_top3_threshold": 60.0,
              "conversion_issue_threshold": 15.0,
              "winning_eval_threshold": 200.0,
              "losing_eval_threshold": -200.0,
              "defensive_weakness_threshold": 20.0,
              "inaccuracy_rate_threshold": 25.0,
              "repeated_position_min_games_blunder": 2,
              "repeated_position_min_games_mistake": 2,
              "repeated_position_min_games_miss": 2,
              "repeated_position_min_games_inaccuracy": 2
            }
          },
          "move_classification_pie": {
            "enabled": true,
            "show_opponent_overlay": true,
            "hover_overlay_animation_ms": 1200,
            "player_legend_label": "Player",
            "opponent_legend_label": "Opponents"
          },
          "phase_bar_chart": {
            "show_opponent_hover_overlay": true,
            "hover_overlay_animation_ms": 1200,
            "player_legend_label": "Player",
            "opponent_legend_label": "Opponents"
          },
          "opening_tree": {
            "max_depth": 12,
            "min_games": 1,
            "initial_expand_depth": 2
          },
          "endgame_tree": {
            "initial_expand_depth": 0
          },
          "accuracy_vs_progress_chart": {
            "enabled": true,
            "progress_bins": 21,
            "show_bin_data_markers": true
          },
          "time_series": {
            "min_games_with_full_date": 4,
            "min_span_days": 14,
            "min_populated_bins": 1,
            "target_progression_bins": 16,
            "max_ordinal_bins": 120,
            "min_games_per_ordinal_bin": 3,
            "ordinal_fallback_mode": "quantile",
            "ordinal_fallback_subcaption_suffix": "",
            "progression_x_axis_mode": "uniform_bins",
            "compress_gap_max_segment_days": 28,
            "show_bin_data_markers": true,
            "x_axis_calendar_enabled": true,
            "x_axis_week_ticks_in_month_mode": true,
            "x_axis_week_minor_max_calendar_span_days": 100,
            "x_axis_month_ticks_in_year_mode": true
          },
          "activity_heatmap": {
            "enabled": true
          },
          "accuracy_over_time_chart": {
            "enabled": true,
            "subcaption_template": "Based on {dated} dated games (of {analyzed} analyzed).",
            "show_accuracy_by_color_lines": true,
            "combined_series_label": "Combined",
            "white_series_label": "As White",
            "black_series_label": "As Black"
          },
          "move_quality_over_time_chart": {
            "enabled": true,
            "subcaption_template": "Based on {dated} dated games (of {analyzed} analyzed)."
          },
          "acpl_phase_over_time_chart": {
            "enabled": true,
            "subcaption_template": "Median ACPL per phase; {dated} dated games (of {analyzed} analyzed). Lower is better."
          }
        },
        "manual_analysis": {
          "multipv1_indicator": {
            "enabled": true
          },
          "multipv2_indicator": {
            "enabled": true
          },
          "multipv3_indicator": {
            "enabled": true
          },
          "statistics": {
            "enabled": true,
            "show_nps": true,
            "show_hash": true,
            "show_time": true,
            "show_nodes": false,
            "format": "compact",
            "separator": " | "
          },
          "evaluation_difference": {
            "enabled": true,
            "show_delta": true,
            "delta_format": "({delta:+.2f})"
          },
          "trajectory_highlight": {
            "enabled": true
          },
          "pv_hover": {
            "enabled": true,
            "restore_on_leave": true
          },
          "default_threads_formula": {
            "formula": "max(1, min(12, cpu_count - reserved_cores))"
          },
          "update_interval_ms": 100,
          "max_depth": null
        },
        "ai_chat": {
          "tokens": {
            "minimum": 256,
            "maximum": 16000,
            "default": 2000,
            "step": 100
          }
        },
        "notes": {
          "heading_font_point_sizes": {
            "h1": 13,
            "h2": 14,
            "h3": 15,
            "h4": 16,
            "h5": 17,
            "h6": 18
          },
          "hidden_marker_font_point_size": 0.5,
          "placeholder_text": "Add notes about this game..."
        }
      },
      "database": {
        "pgn_col_max_chars": 300,
        "table": {
          "columns": {
            "col_num": "#",
            "col_file_num": "# in File",
            "col_white": "White",
            "col_black": "Black",
            "col_white_elo": "WhiteElo",
            "col_black_elo": "BlackElo",
            "col_result": "Result",
            "col_date": "Date",
            "col_event": "Event",
            "col_site": "Site",
            "col_moves": "Moves",
            "col_eco": "ECO",
            "col_time_control": "TimeControl",
            "col_tc_type": "TC Type",
            "col_analyzed": "Analyzed",
            "col_annotated": "Annotated",
            "col_source_db": "Source DB",
            "col_pgn": "PGN"
          }
        },
        "tc_type": {
          "bullet_max_seconds": 180,
          "blitz_max_seconds": 600,
          "rapid_max_seconds": 3600,
          "string_map": {}
        }
      }
