        "max_threads_spinbox": {
          "min_value": 0,
          "max_value": 128,
          "default_value": 0,
          "single_step": 1,
          "suffix": "",
          "special_value_text": "Unlimited"
        },
        "movetime_spinbox": {
          "min_value": 100,
          "max_value": 60000,
          "default_value": 1000,
          "single_step": 100,
          "suffix": " ms",
          "fallback_default": 1000
