        },
        "backward_pawn": {
          "enabled": true,
          "weight": 1.0,
          "name": "Backward Pawn",
          "description": "Evaluates backward pawns (pawns behind friendly pawns that cannot advance safely)",
          "score": -8.0
        },
        "isolated_pawn": {
          "enabled": true,
          "weight": 1.0,
          "name": "Isolated Pawn",
          "description": "Evaluates isolated pawns (pawns with no friendly pawns on adjacent files)",
