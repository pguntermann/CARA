    "filename": "user_settings.json",
    "template_filename": "user_settings.json.template",
    "player_stats_reset": {
      "confirmation_title": "Reset Player Stats settings",
      "confirmation_message": "Do you want to reset all Player Stats options to the application defaults?",
      "status_success": "Player Stats options reset to application defaults.",
      "status_failed": "Could not reset Player Stats options."
    }
  },
  "game_analysis": {
    "max_depth": 0,
    "time_limit_per_move_ms": 750,
    "default_threads_formula": {
      "formula": "max(1, min(12, cpu_count - reserved_cores))"
    },
    "progress_update_interval_ms": 100,
    "assessment_thresholds": {
      "good_move_max_cpl": 50,
      "inaccuracy_max_cpl": 100,
      "mistake_max_cpl": 200
    },
    "accuracy_formula": {
      "formula": "max(5.0, min(100.0, 100.0 - (average_cpl / 3.5)))",
      "value_on_error": 0.0,
      "_examples": {
        "default": "max(5.0, min(100.0, 100.0 - (average_cpl / 3.5)))",
        "simple": "100.0 - (average_cpl / 2.0)",
        "with_minimum": "max(10.0, 100.0 - (average_cpl / 3.0))",
        "penalize_poor_opening": "max(5.0, min(100.0, 100.0 - (average_cpl / 3.5) - ((average_cpl_opening - average_cpl) * 0.15)))",
        "weight_by_phase_distribution": "max(5.0, min(100.0, 100.0 - ((average_cpl_opening * opening_moves + average_cpl_middlegame * middlegame_moves + average_cpl_endgame * endgame_moves) / max(total_moves, 1) / 3.5)))",
        "bonus_for_consistent_phases": "max(5.0, min(100.0, 100.0 - (average_cpl / 3.5) + (10.0 - abs(average_cpl_opening - average_cpl) - abs(average_cpl_middlegame - average_cpl) - abs(average_cpl_endgame - average_cpl)) * 0.5))"
      }
    },
    "phase_accuracy_formulas": {
      "opening": {
        "formula": "max(5.0, min(100.0, 100.0 - (average_cpl_opening / 3.5)))",
        "value_on_error": 0.0,
        "_examples": {
          "default": "max(5.0, min(100.0, 100.0 - (average_cpl_opening / 3.5)))",
          "compare_to_overall_cpl": "max(5.0, min(100.0, 100.0 - (average_cpl_opening / 3.5) - ((average_cpl_opening - average_cpl) * 0.15)))",
          "penalize_worse_than_overall": "max(5.0, min(100.0, 100.0 - (average_cpl_opening / 3.5) - max(0, (average_cpl_opening - average_cpl) * 0.2)))",
          "compare_blunder_rate": "max(5.0, min(100.0, 100.0 - (average_cpl_opening / 3.5) - ((blunder_rate - blunder_rate_overall) * 30.0)))",
          "weight_by_opening_length": "max(5.0, min(100.0, 100.0 - (average_cpl_opening / 3.5) * (opening_moves / max(total_moves_overall, 1))))"
        }
      },
      "middlegame": {
        "formula": "max(5.0, min(100.0, 100.0 - (average_cpl_middlegame / 3.5)))",
        "value_on_error": 0.0,
        "_examples": {
          "default": "max(5.0, min(100.0, 100.0 - (average_cpl_middlegame / 3.5)))",
          "compare_to_overall_cpl": "max(5.0, min(100.0, 100.0 - (average_cpl_middlegame / 3.5) - ((average_cpl_middlegame - average_cpl) * 0.15)))",
          "bonus_if_better_than_opening": "max(5.0, min(100.0, 100.0 - (average_cpl_middlegame / 3.5) + max(0, (average_cpl_opening - average_cpl_middlegame) * 0.1)))",
          "compare_mistake_rate": "max(5.0, min(100.0, 100.0 - (average_cpl_middlegame / 3.5) - ((mistake_rate - mistake_rate_overall) * 25.0)))",
          "weight_by_middlegame_length": "max(5.0, min(100.0, 100.0 - (average_cpl_middlegame / 3.5) * (middlegame_moves / max(total_moves_overall, 1))))"
        }
      },
      "endgame": {
        "formula": "max(5.0, min(100.0, 100.0 - (average_cpl_endgame / 3.5)))",
        "value_on_error": 0.0,
        "_examples": {
          "default": "max(5.0, min(100.0, 100.0 - (average_cpl_endgame / 3.5)))",
          "compare_to_overall_cpl": "max(5.0, min(100.0, 100.0 - (average_cpl_endgame / 3.5) - ((average_cpl_endgame - average_cpl) * 0.15)))",
