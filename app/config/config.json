    "dialogs": {
      "ai_model_settings": {
        "default_custom_base_url": "http://localhost:1234/v1",
        "custom_endpoint_disclaimer": {
          "title": "Custom Endpoint Disclaimer",
          "message": "<b>Experimental feature:</b> Custom endpoint support is an experimental implementation. Responses from locally run models may not match the quality of top-tier cloud models (e.g. OpenAI GPT-4, Anthropic Claude).<br><br>Local models may be less accurate, less consistent, or occasionally produce incorrect or irrelevant answers. Use at your own discretion."
        }
      },
